# Server
PORT=5000
NODE_ENV=development

# Neon PostgreSQL (serverless)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/placement_portal?sslmode=require

# JWT — keep access token short-lived, refresh token is stored in DB
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRES_IN=15m

# CORS - Frontend URL
CLIENT_URL=http://localhost:3000
